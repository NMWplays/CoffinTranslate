<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CoffinTranslate.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <!-- opaque, theme-aware surface colors for floating elements (custom dropdown popup) -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CtSurface" Color="#FCFCFD" />
                    <SolidColorBrush x:Key="CtSurfaceBorder" Color="#22000000" />
                    <SolidColorBrush x:Key="CtIslandBg" Color="#0F808080" />
                    <SolidColorBrush x:Key="CtIslandBorder" Color="#20808080" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CtSurface" Color="#2B2B33" />
                    <SolidColorBrush x:Key="CtSurfaceBorder" Color="#33FFFFFF" />
                    <SolidColorBrush x:Key="CtIslandBg" Color="#16FFFFFF" />
                    <SolidColorBrush x:Key="CtIslandBorder" Color="#2EFFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- shared vector icons (Material Design Icons paths, 24x24 viewBox) -->
            <StreamGeometry x:Key="IconSettings">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
            <StreamGeometry x:Key="IconSpeaker">M9,12A3,3 0 0,0 12,9A3,3 0 0,0 9,6A3,3 0 0,0 6,9A3,3 0 0,0 9,12M9,14C6.33,14 1,15.33 1,18V20H17V18C17,15.33 11.67,14 9,14M16.76,5.36L15.08,7.05C15.92,8.29 15.92,9.7 15.08,10.94L16.76,12.63C18.78,10.61 18.78,7.53 16.76,5.36M20.07,2L18.39,3.69C21.44,6.9 21.44,11.9 18.39,15.31L20.07,17C24.15,12.9 24.16,6.35 20.07,2Z</StreamGeometry>
            <StreamGeometry x:Key="IconJump">M20,13.5A6.5,6.5 0 0,1 13.5,20H6V18H13.5A4.5,4.5 0 0,0 18,13.5A4.5,4.5 0 0,0 13.5,9H7.83L10.91,12.09L9.5,13.5L4,8L9.5,2.5L10.91,3.91L7.83,7H13.5A6.5,6.5 0 0,1 20,13.5Z</StreamGeometry>
            <StreamGeometry x:Key="IconClose">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</StreamGeometry>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="Opacity" Value="0.65" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style Selector="TextBlock.error">
            <Setter Property="Foreground" Value="#E5484D" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.warning">
            <Setter Property="Foreground" Value="#C08A00" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ============================================================
             Buttons: softly rounded with a subtle scale-on-hover effect
             ============================================================ -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15,7" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.045)" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="RenderTransform" Value="none" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#C42B1C" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- ============================================================
             Islands: the app's main surfaces (sidebar, page area, editor
             panes) float as rounded, softly bordered panels.
             ============================================================ -->
        <Style Selector="Border.island">
            <Setter Property="Background" Value="{DynamicResource CtIslandBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CtIslandBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <!-- flat sub-panel used inside pages (low-alpha gray overlay, theme-safe) -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#14808080" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="Border.dropzone">
            <Setter Property="BorderBrush" Value="#40808080" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Border.dropzone.dragover">
            <Setter Property="BorderBrush" Value="#3FB950" />
            <Setter Property="Background" Value="#143FB950" />
        </Style>

        <!-- ============================================================
             Sidebar navigation entries: roomy, rounded, hover feedback.
             Horizontal margin insets each item from the container clip so
             the hover scale has room and isn't cut off at the sides.
             ============================================================ -->
        <Style Selector="ListBox.nav">
            <Setter Property="Padding" Value="4,3" />
        </Style>
        <Style Selector="ListBox.nav > ListBoxItem">
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.nav > ListBoxItem:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.03)" />
        </Style>

        <!-- ============================================================
             Editor "map name" section list: padded, rounded, hover lift
             ============================================================ -->
        <Style Selector="ListBox.sections > ListBoxItem">
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.sections > ListBoxItem:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.03)" />
        </Style>

        <!-- ============================================================
             Editor translation rows: a softly rounded box around the
             source+target fields. On hover it squares off and grows just
             past its bounds, lifting the active row above the list.
             ============================================================ -->
        <!-- stays rounded; on hover it only lightens (no scale/square-off — that
             was distracting while editing the fields) -->
        <Style Selector="Border.unit">
            <Setter Property="Background" Value="#0D808080" />
            <Setter Property="BorderBrush" Value="#14808080" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.unit:pointerover">
            <Setter Property="Background" Value="#1A808080" />
            <Setter Property="BorderBrush" Value="#2E808080" />
        </Style>

        <!-- neutralize the ListBox chrome for the units list: no selection/
             hover highlight of its own, the card handles all feedback -->
        <Style Selector="ListBox.units > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="ListBox.units > ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ============================================================
             Custom dropdown (used for the UI-language picker in Settings):
             a modern rounded toggle button + a rounded popup list with
             per-item hover. Fully self-styled, no Fluent ComboBox chrome.
             ============================================================ -->
        <Style Selector="Button.dropdown">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="15,11" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <!-- kill the global button hover-scale for the dropdown toggle; it uses a bg change instead -->
        <Style Selector="Button.dropdown:pointerover">
            <Setter Property="RenderTransform" Value="none" />
        </Style>
        <Style Selector="Button.dropdown:pressed">
            <Setter Property="RenderTransform" Value="none" />
        </Style>
        <Style Selector="Button.dropdown /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#14808080" />
            <Setter Property="BorderBrush" Value="#28808080" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Button.dropdown:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#20808080" />
            <Setter Property="BorderBrush" Value="#3A808080" />
        </Style>
        <Style Selector="Button.dropdown:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28808080" />
        </Style>

        <!-- the floating popup surface -->
        <Style Selector="Border.dropdown-popup">
            <Setter Property="Background" Value="{DynamicResource CtSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CtSurfaceBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <!-- generous padding so an item's hover-scale grows into it and isn't clipped -->
            <Setter Property="Padding" Value="8" />
            <Setter Property="BoxShadow" Value="0 12 32 0 #40000000" />
        </Style>

        <!-- Flyout dropdown (Export menu): a Button.Flyout whose presenter is restyled to
             match the custom dropdown look. The Flyout anchors to its button automatically,
             so placement is reliable even inside the responsive top bar. -->
        <Style Selector="FlyoutPresenter.dropdown-flyout">
            <Setter Property="Background" Value="{DynamicResource CtSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CtSurfaceBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="400" />
        </Style>

        <!-- popup items are Buttons in a (non-clipping) ItemsControl, so the hover
             scale can grow past the item bounds without being cut off -->
        <Style Selector="Button.dropdown-item">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="13,10" />
            <!-- horizontal margin insets the button from the item-container clip so the
                 hover highlight + scale have room and aren't cut off at the sides -->
            <Setter Property="Margin" Value="6,3" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.dropdown-item:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.035)" />
        </Style>
        <Style Selector="Button.dropdown-item /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.dropdown-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28808080" />
        </Style>
        <Style Selector="Button.dropdown-item:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#363B82F6" />
        </Style>

        <!-- ============================================================
             Full-width list buttons (recent projects on the editor start).
             Horizontal margin insets the button from the item-container clip
             so the hover-scale has room and isn't cut off at the sides.
             ============================================================ -->
        <Style Selector="Button.recent">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="8,0,8,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        </Style>
        <Style Selector="Button.recent:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)" />
        </Style>
        <Style Selector="Button.recent /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#10808080" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style Selector="Button.recent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#20808080" />
        </Style>

        <!-- ============================================================
             NumericUpDown: keep the rounded corners in every state. The
             inner TextBox otherwise reverts to the small default radius on
             hover/focus, making the control look less rounded.
             ============================================================ -->
        <Style Selector="NumericUpDown">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="NumericUpDown /template/ ButtonSpinner">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <!-- ============================================================
             Segmented buttons: the editor's view tabs (Texte/Bilder) and
             the filter chips (all / untranslated / translated).
             ============================================================ -->
        <Style Selector="Button.seg">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="13,7" />
        </Style>
        <Style Selector="Button.seg /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#12808080" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style Selector="Button.seg:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#20808080" />
        </Style>
        <Style Selector="Button.seg.active">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.seg.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#3B82F6" />
        </Style>
        <Style Selector="Button.seg.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4B8DF8" />
        </Style>
    </Application.Styles>
</Application>
