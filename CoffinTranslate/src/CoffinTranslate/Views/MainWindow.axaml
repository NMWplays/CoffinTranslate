<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CoffinTranslate.ViewModels"
        xmlns:views="using:CoffinTranslate.Views"
        xmlns:loc="using:CoffinTranslate.Services"
        x:Class="CoffinTranslate.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/AppIcon.ico"
        Title="CoffinTranslate"
        Width="1120" Height="720"
        MinWidth="960" MinHeight="560"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="Auto,*">

        <!-- sidebar island -->
        <Border Grid.Column="0" Classes="island" Width="212" Margin="12,12,6,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="CoffinTranslate"
                           FontSize="17" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="12,22,12,20" />

                <ListBox Classes="nav" Margin="10,0,10,10" Background="Transparent"
                         SelectedIndex="{Binding SelectedPageIndex}">
                    <ListBoxItem>
                        <TextBlock Text="{loc:Localize Nav_Install}" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="{loc:Localize Nav_Manage}" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="{loc:Localize Nav_Editor}" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="{loc:Localize Nav_Settings}" />
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- page area: cross-fades between pages when the navigation changes -->
        <TransitioningContentControl Grid.Column="1" Margin="6,12,12,12"
                                     Content="{Binding CurrentPage}">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="0:0:0.22" />
            </TransitioningContentControl.PageTransition>
            <TransitioningContentControl.DataTemplates>
                <DataTemplate DataType="vm:InstallViewModel">
                    <Border Classes="island" ClipToBounds="True">
                        <views:InstallView />
                    </Border>
                </DataTemplate>
                <DataTemplate DataType="vm:ManageViewModel">
                    <Border Classes="island" ClipToBounds="True">
                        <views:ManageView />
                    </Border>
                </DataTemplate>
                <!-- the editor lays out its own islands -->
                <DataTemplate DataType="vm:EditorViewModel">
                    <views:EditorView />
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <Border Classes="island" ClipToBounds="True">
                        <views:SettingsView />
                    </Border>
                </DataTemplate>
            </TransitioningContentControl.DataTemplates>
        </TransitioningContentControl>
    </Grid>
</Window>
