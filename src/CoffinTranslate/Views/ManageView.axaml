<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CoffinTranslate.ViewModels"
             xmlns:loc="using:CoffinTranslate.Services"
             x:Class="CoffinTranslate.Views.ManageView"
             x:DataType="vm:ManageViewModel">

    <ScrollViewer>
        <StackPanel Margin="36,28" Spacing="14" MaxWidth="760">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="h1" Text="{loc:Localize Manage_Title}" />
                    <TextBlock Classes="subtitle" Text="{loc:Localize Manage_Subtitle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Top" Margin="12,4,0,0">
                    <Button Classes="accent"
                            Content="{loc:Localize Manage_LaunchGame}"
                            Command="{Binding LaunchGameCommand}"
                            IsVisible="{Binding CanLaunchGame}" />
                    <Button Content="{loc:Localize Manage_Refresh}"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>

            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" />

            <TextBlock Text="{Binding StatusMessage}" Opacity="0.75" TextWrapping="Wrap"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <TextBlock Text="{loc:Localize Manage_NoGame}" Opacity="0.6" TextWrapping="Wrap"
                       IsVisible="{Binding !HasGame}" />
            <TextBlock Text="{loc:Localize Manage_Empty}" Opacity="0.6" TextWrapping="Wrap"
                       IsVisible="{Binding IsEmpty}" />

            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:InstalledItemViewModel">
                        <Border Classes="card" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding DisplayLanguage}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Opacity="0.7" FontSize="13" />
                                    <TextBlock Text="{Binding PathText}" Opacity="0.5" FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button Content="{loc:Localize Manage_OpenFolder}"
                                            Command="{Binding OpenFolderCommand}"
                                            IsVisible="{Binding !IsConfirmingRemove}" />
                                    <Button Content="{loc:Localize Manage_Remove}"
                                            Command="{Binding BeginRemoveCommand}"
                                            IsVisible="{Binding !IsConfirmingRemove}" />
                                    <Button Classes="danger"
                                            Content="{loc:Localize Manage_ConfirmYes}"
                                            Command="{Binding ConfirmRemoveCommand}"
                                            IsVisible="{Binding IsConfirmingRemove}" />
                                    <Button Content="{loc:Localize Manage_Cancel}"
                                            Command="{Binding CancelRemoveCommand}"
                                            IsVisible="{Binding IsConfirmingRemove}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
