<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CoffinTranslate.ViewModels"
             xmlns:loc="using:CoffinTranslate.Services"
             xmlns:ctrl="using:CoffinTranslate.Controls"
             xmlns:sys="using:System"
             x:Class="CoffinTranslate.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    </UserControl.KeyBindings>

    <Panel>
        <!-- START SCREEN -->
        <Border Classes="island" ClipToBounds="True" IsVisible="{Binding ShowStart}">
            <ScrollViewer>
                <StackPanel Margin="36,28" Spacing="14" MaxWidth="760">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Classes="h1" Text="{loc:Localize Editor_Title}" />
                        <Border Background="#3B82F6" CornerRadius="7" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Localize Editor_Badge_Advanced}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <TextBlock Classes="subtitle" Text="{loc:Localize Editor_Subtitle}" />

                    <TextBlock Classes="warning" Margin="0,4,0,0"
                               Text="{loc:Localize Editor_NeedGame}"
                               IsVisible="{Binding ShowNeedGame}" />

                    <Border Classes="card" Margin="0,8,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Localize Editor_Start_Create_Title}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Localize Editor_Start_Create_Hint}" Opacity="0.7" TextWrapping="Wrap" />
                            <Button Classes="accent" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Content="{loc:Localize Editor_Start_Create_Button}"
                                    Command="{Binding CreateFromGameCommand}"
                                    IsEnabled="{Binding CanCreate}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Localize Editor_Start_Open_Title}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Localize Editor_Start_Open_Hint}" Opacity="0.7" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Content="{loc:Localize Editor_Start_OpenProject_Button}"
                                        Command="{Binding OpenProjectCommand}" />
                                <Button Content="{loc:Localize Editor_Start_Open_Button}"
                                        Command="{Binding OpenExistingCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" IsVisible="{Binding HasRecentProjects}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Localize Editor_Recent_Title}" FontSize="16" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding RecentProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RecentProjectItem">
                                        <Button Classes="recent"
                                                Command="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).OpenRecentCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Folder}" Opacity="0.5" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Classes="error" Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- BUSY -->
        <Border Classes="island" IsVisible="{Binding IsBusy}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="220" />
                <TextBlock Text="{loc:Localize Editor_Loading}" Opacity="0.7" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- EDITOR -->
        <Grid IsVisible="{Binding HasProject}" RowDefinitions="Auto,Auto,*">

            <!-- Top bars as super-islands (IslandFlowPanel draws the island chrome itself):
                   • Island 1 = language+version (left) … settings/save/export/close (right)
                   • Island 2 = tabs+search+speaker+jump (left) … zoom+filters (right)
                 While a super-island's two groups fit on one line they share one island bar; when
                 they don't, the trailing group drops onto its own full-width, centered island. -->
            <ctrl:IslandFlowPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">

                <!-- Island 1 · left: language name + progress + version -->
                <StackPanel ctrl:IslandFlowPanel.Island="1"
                            Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Localize Editor_LanguageName_Label}"
                               VerticalAlignment="Center" Opacity="0.7" />
                    <TextBox MinWidth="130" MaxWidth="170" CornerRadius="10"
                             Text="{Binding LanguageName}"
                             PlaceholderText="{loc:Localize Editor_LanguageName_Watermark}" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="{Binding OverallProgress}" Opacity="0.75" FontSize="12" />
                        <TextBlock Text="{Binding ProjectVersionInfo}" Opacity="0.45" FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding ProjectVersionInfo, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Island 1 · right: settings / save / export / close -->
                <StackPanel ctrl:IslandFlowPanel.Island="1" ctrl:IslandFlowPanel.Trailing="True"
                            Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button ToolTip.Tip="{loc:Localize Editor_Settings}"
                            Classes.accent="{Binding ShowSettings}"
                            Command="{Binding ToggleSettingsCommand}">
                        <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16" />
                    </Button>
                    <Button Command="{Binding SaveProjectCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="#F0A000" VerticalAlignment="Center"
                                     IsVisible="{Binding HasUnsavedChanges}" />
                            <TextBlock Text="{loc:Localize Editor_Save}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="accent" Padding="15,7">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{loc:Localize Editor_Export}" />
                            <TextBlock Text="▾" Opacity="0.7" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight" VerticalOffset="6"
                                    FlyoutPresenterClasses="dropdown-flyout">
                                <StackPanel MinWidth="180">
                                    <Button Classes="dropdown-item" Content="{loc:Localize Editor_Export_Folder}"
                                            Command="{Binding ExportCommand}" />
                                    <Button Classes="dropdown-item" Content="{loc:Localize Editor_Export_Zip}"
                                            Command="{Binding ExportZipCommand}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button ToolTip.Tip="{loc:Localize Editor_Close}"
                            Command="{Binding CloseProjectCommand}">
                        <PathIcon Data="{StaticResource IconClose}" Width="14" Height="14" />
                    </Button>
                </StackPanel>

                <!-- Island 2 · left: view tabs + search + speaker + jump -->
                <StackPanel ctrl:IslandFlowPanel.Island="2"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button Classes="seg" Classes.active="{Binding ShowTextView}"
                                Content="{loc:Localize Editor_Tab_Texts}"
                                Command="{Binding ShowTextsCommand}" />
                        <Button Classes="seg" Classes.active="{Binding ShowImagesView}"
                                Content="{Binding ImagesTabLabel}"
                                Command="{Binding ShowImagesCommand}" />
                        <Button Classes="seg" Classes.active="{Binding ShowStatsView}"
                                Content="{loc:Localize Editor_Tab_Stats}"
                                Command="{Binding ShowStatsCommand}" />
                    </StackPanel>

                    <!-- search + speaker + jump (text view only) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0" VerticalAlignment="Center"
                                IsVisible="{Binding ShowTextView}">
                        <Border Width="1" Background="#2E808080" Margin="0,1,4,1" />
                        <TextBox x:Name="SearchBox" CornerRadius="9" MinWidth="150" MaxWidth="280"
                                 VerticalAlignment="Center"
                                 Text="{Binding SearchText}"
                                 PlaceholderText="{loc:Localize Editor_Search_Watermark}" />

                        <!-- speaker filter: same custom light-dismiss dropdown as the language picker -->
                        <Panel IsVisible="{Binding HasSpeakerFilter}" VerticalAlignment="Center">
                            <Button x:Name="SpeakerButton" Classes="seg"
                                    Classes.active="{Binding SelectedSpeaker, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Command="{Binding ToggleSpeakerCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource IconSpeaker}" Width="13" Height="13" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SpeakerFilterLabel}" MaxWidth="130"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Text="▾" Opacity="0.6" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Popup PlacementTarget="{Binding #SpeakerButton}" Placement="BottomEdgeAlignedLeft"
                                   IsOpen="{Binding IsSpeakerOpen, Mode=TwoWay}"
                                   IsLightDismissEnabled="True" VerticalOffset="6">
                                <Border Classes="dropdown-popup" MinWidth="{Binding #SpeakerButton.Bounds.Width}">
                                    <ScrollViewer MaxHeight="360">
                                        <StackPanel>
                                            <Button Classes="dropdown-item" Content="{loc:Localize Editor_Speaker_All}"
                                                    Command="{Binding SetSpeakerCommand}" CommandParameter="" />
                                            <ItemsControl ItemsSource="{Binding Speakers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="sys:String">
                                                        <Button Classes="dropdown-item" Content="{Binding}"
                                                                Command="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).SetSpeakerCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>

                        <Button Classes="seg"
                                ToolTip.Tip="{loc:Localize Editor_JumpLastEdit_Tip}"
                                IsVisible="{Binding CanJumpToLastEdit}"
                                Command="{Binding JumpToLastEditCommand}">
                            <PathIcon Data="{StaticResource IconJump}" Width="15" Height="15" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Island 2 · right: zoom + filters (text view only) -->
                <StackPanel ctrl:IslandFlowPanel.Island="2" ctrl:IslandFlowPanel.Trailing="True"
                            Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            IsVisible="{Binding ShowTextView}">
                    <Button Classes="seg" Content="A−" FontSize="13"
                            ToolTip.Tip="{loc:Localize Editor_Zoom_Out}"
                            Command="{Binding ZoomOutCommand}" />
                    <Button Classes="seg" Content="A+" FontSize="15"
                            ToolTip.Tip="{loc:Localize Editor_Zoom_In}"
                            Command="{Binding ZoomInCommand}" />
                    <Border Width="1" Background="#2E808080" Margin="4,3" />
                    <Button Classes="seg" Classes.active="{Binding IsFilterAll}"
                            Content="{loc:Localize Editor_Filter_All}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static vm:EditorFilter.All}" />
                    <Button Classes="seg" Classes.active="{Binding IsFilterUntranslated}"
                            Content="{loc:Localize Editor_Filter_Untranslated}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static vm:EditorFilter.Untranslated}" />
                    <Button Classes="seg" Classes.active="{Binding IsFilterTranslated}"
                            Content="{loc:Localize Editor_Filter_Translated}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static vm:EditorFilter.Translated}" />
                    <Button Classes="seg" Classes.active="{Binding IsFilterNew}"
                            Content="{loc:Localize Editor_Filter_New}"
                            IsVisible="{Binding HasNewUnits}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static vm:EditorFilter.New}" />
                </StackPanel>
            </ctrl:IslandFlowPanel>

            <!-- Extras row: project-settings card, status/error, version banner. Full width, only
                 shown when there's something to show. -->
            <Border Grid.Row="1" Classes="island" Padding="16,12" Margin="0,0,0,10"
                    IsVisible="{Binding ShowTopExtras}">
                <StackPanel Spacing="10">
                    <!-- project settings: font + credits (the game's "first row set") -->
                    <StackPanel Spacing="10" IsVisible="{Binding ShowSettings}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" >
                            <TextBlock Grid.Column="0" Text="{loc:Localize Editor_Font_Label}"
                                       VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7" />
                            <TextBox Grid.Column="1" CornerRadius="8" MaxWidth="260" HorizontalAlignment="Left"
                                     Text="{Binding FontFace}"
                                     PlaceholderText="{loc:Localize Editor_Font_Watermark}" />
                            <Button Grid.Column="2" Margin="8,0,0,0"
                                    Content="{loc:Localize Editor_Font_Pick}"
                                    Command="{Binding PickFontFileCommand}" />
                            <TextBlock Grid.Column="3" Text="{loc:Localize Editor_Font_Size}"
                                       VerticalAlignment="Center" Margin="18,0,8,0" Opacity="0.7" />
                            <NumericUpDown Grid.Column="4" Width="120" Minimum="1" Maximum="200"
                                           Increment="1" FormatString="0" CornerRadius="8"
                                           Value="{Binding FontSize}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasFontFile}">
                            <TextBlock Text="{loc:Localize Editor_Font_Bundled}" Opacity="0.55" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FontFileName}" FontSize="12" VerticalAlignment="Center" />
                            <Button Content="{loc:Localize Editor_Font_ClearFile}" Padding="9,3"
                                    Command="{Binding ClearFontFileCommand}" />
                        </StackPanel>

                        <!-- live font preview: sample text at the project's font size -->
                        <Border Background="#10808080" CornerRadius="8" Padding="12,10">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{loc:Localize Editor_Font_Preview}" Opacity="0.5" FontSize="11" />
                                <TextBlock Text="{loc:Localize Editor_Font_PreviewText}" TextWrapping="Wrap"
                                           FontFamily="{Binding PreviewFontFamily}" FontSize="{Binding PreviewFontSize}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{loc:Localize Editor_Credits_Label}" Opacity="0.7" Margin="0,2,0,0" />
                        <TextBlock Text="{loc:Localize Editor_Credits_Hint}" Opacity="0.5" FontSize="12" TextWrapping="Wrap" />
                        <TextBox CornerRadius="8" Text="{Binding Credit1}" MaxWidth="420" HorizontalAlignment="Left"
                                 PlaceholderText="{loc:Localize Editor_Credits_Line1}" />
                        <TextBox CornerRadius="8" Text="{Binding Credit2}" MaxWidth="420" HorizontalAlignment="Left"
                                 PlaceholderText="{loc:Localize Editor_Credits_Line2}" />
                        <TextBox CornerRadius="8" Text="{Binding Credit3}" MaxWidth="420" HorizontalAlignment="Left"
                                 PlaceholderText="{loc:Localize Editor_Credits_Line3}" />
                    </StackPanel>

                    <TextBlock Classes="error" Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#3FB950" TextWrapping="Wrap"
                               IsVisible="{Binding HasStatus}" />
                    <Border Background="#26C08A00" BorderBrush="#66C08A00" BorderThickness="1"
                            CornerRadius="8" Padding="12,8"
                            IsVisible="{Binding ShowVersionWarning}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Classes="accent" VerticalAlignment="Center" Margin="12,0,0,0"
                                    Content="{loc:Localize Editor_Update}"
                                    ToolTip.Tip="{loc:Localize Editor_Update_Tip}"
                                    IsVisible="{Binding CanUpdateFromGame}"
                                    Command="{Binding UpdateFromGameCommand}" />
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="⚠" Foreground="#C08A00"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Classes="warning" Text="{Binding VersionWarningText}"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Grid>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- TEXT VIEW: sections island + translation island -->
            <Grid Grid.Row="2" ColumnDefinitions="260,*" ColumnSpacing="10"
                  IsVisible="{Binding ShowTextView}">

                <Border Grid.Column="0" Classes="island" ClipToBounds="True">
                    <ListBox Classes="sections" Padding="8" Background="Transparent"
                             ItemsSource="{Binding VisibleSections}"
                             SelectedItem="{Binding SelectedSection}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorSectionViewModel">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                                               Opacity="0.5" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Column="1" Classes="island" ClipToBounds="True">
                    <Panel>
                        <ListBox x:Name="UnitsList" Classes="units" Padding="14,12" Background="Transparent"
                                 ItemsSource="{Binding VisibleUnits}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:EditorUnitViewModel">
                                    <Border Classes="unit" Margin="0,0,0,10">
                                        <StackPanel Spacing="7">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="⚠" Foreground="#C08A00"
                                                           IsVisible="{Binding HasTagWarning}"
                                                           ToolTip.Tip="{loc:Localize Editor_TagWarning}" />
                                                <TextBlock DockPanel.Dock="Right" Text="✓" Foreground="#3FB950" Margin="0,0,8,0"
                                                           IsVisible="{Binding IsTranslated}" />
                                                <Border DockPanel.Dock="Right" Background="#3B82F6" CornerRadius="6"
                                                        Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center"
                                                        IsVisible="{Binding IsNew}"
                                                        ToolTip.Tip="{loc:Localize Editor_Badge_New_Tip}">
                                                    <TextBlock Text="{loc:Localize Editor_Badge_New}" Foreground="White"
                                                               FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Text="{Binding Header}" Opacity="0.55" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </DockPanel>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <TextBox Grid.Column="0" Text="{Binding Source, Mode=OneWay}"
                                                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Background="Transparent" Opacity="0.75" CornerRadius="7"
                                                         FontSize="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).EditorFontSize}" />
                                                <TextBox Grid.Column="1" Text="{Binding TargetText}"
                                                         TextWrapping="Wrap" AcceptsReturn="True" CornerRadius="7"
                                                         FontSize="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).EditorFontSize}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="{loc:Localize Editor_NoResults}" Opacity="0.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding HasNoVisibleUnits}" />
                    </Panel>
                </Border>
            </Grid>

            <!-- IMAGES VIEW -->
            <Border Grid.Row="2" Classes="island" ClipToBounds="True"
                    IsVisible="{Binding ShowImagesView}">
                <Panel>
                    <ScrollViewer>
                        <StackPanel Margin="16" Spacing="10">
                            <TextBlock Text="{loc:Localize Editor_Images_Intro}" Opacity="0.7" TextWrapping="Wrap" MaxWidth="820" />
                            <ItemsControl x:Name="ImagesItems" ItemsSource="{Binding Images}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding #ImagesItems.Bounds.Width, Converter={x:Static loc:WidthToColumnsConverter.Instance}, ConverterParameter=300}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EditorImageViewModel">
                                        <Border Classes="card" Margin="6" Padding="12"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Top">
                                            <StackPanel Spacing="7">
                                                <TextBlock Text="{Binding FolderLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ShortName}" Opacity="0.45" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid ColumnDefinitions="*,Auto,*" Height="118">
                                                    <Border Grid.Column="0" Background="#1A808080" CornerRadius="6" Padding="4">
                                                        <Image Source="{Binding OriginalPreview}" Stretch="Uniform" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="→" Opacity="0.5" Margin="7,0"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2" Background="#1A808080" CornerRadius="6" Padding="4">
                                                        <Panel>
                                                            <Image Source="{Binding ReplacementPreview}" Stretch="Uniform"
                                                                   IsVisible="{Binding HasReplacement}" />
                                                            <TextBlock Text="{loc:Localize Editor_Images_Original}" Opacity="0.35"
                                                                       FontSize="11" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                                                       TextAlignment="Center"
                                                                       IsVisible="{Binding !HasReplacement}" />
                                                        </Panel>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Classes="warning" FontSize="11" TextWrapping="Wrap"
                                                           Text="{loc:Localize Editor_Images_Missing}"
                                                           IsVisible="{Binding ReplacementMissing}" />
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Padding="10,4" Content="{loc:Localize Editor_Images_Replace}"
                                                            Command="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).ReplaceImageCommand}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Padding="10,4" Content="{loc:Localize Editor_Images_Open}"
                                                            Command="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).OpenImageCommand}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Padding="10,4" Content="{loc:Localize Editor_Images_Clear}"
                                                            IsVisible="{Binding HasReplacement}"
                                                            Command="{Binding $parent[ItemsControl].((vm:EditorViewModel)DataContext).ClearImageCommand}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                                IsVisible="{Binding ImagesBusy}">
                        <ProgressBar IsIndeterminate="True" Width="200" />
                        <TextBlock Text="{loc:Localize Editor_Images_Loading}" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding ImagesMessage}" Classes="warning" Margin="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                               IsVisible="{Binding ImagesMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                </Panel>
            </Border>

            <!-- STATISTICS VIEW -->
            <Border Grid.Row="2" Classes="island" ClipToBounds="True"
                    IsVisible="{Binding ShowStatsView}">
                <ScrollViewer>
                    <StackPanel Margin="22" Spacing="16" MaxWidth="720" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Editor_Stats_Title}" FontSize="17" FontWeight="SemiBold" />

                        <!-- overall progress -->
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding ProgressPercent}" FontSize="28" FontWeight="Bold" />
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}" Height="10" />
                                <UniformGrid Columns="3" Margin="0,4,0,0">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding TranslatedUnits}" FontSize="20" FontWeight="SemiBold" Foreground="#3FB950" />
                                        <TextBlock Text="{loc:Localize Editor_Stats_Translated}" Opacity="0.6" FontSize="12" />
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding UntranslatedUnits}" FontSize="20" FontWeight="SemiBold" Foreground="#C08A00" />
                                        <TextBlock Text="{loc:Localize Editor_Stats_Untranslated}" Opacity="0.6" FontSize="12" />
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding TotalUnits}" FontSize="20" FontWeight="SemiBold" />
                                        <TextBlock Text="{loc:Localize Editor_Stats_Total}" Opacity="0.6" FontSize="12" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- word / char counters -->
                        <Border Classes="card">
                            <UniformGrid Columns="2">
                                <StackPanel Spacing="2">
                                    <TextBlock Opacity="0.6" FontSize="12" Text="{loc:Localize Editor_Stats_Words}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding StatTargetWords}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="/" Opacity="0.4" FontSize="18" />
                                        <TextBlock Text="{Binding StatSourceWords}" FontSize="18" Opacity="0.6" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Opacity="0.6" FontSize="12" Text="{loc:Localize Editor_Stats_Chars}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding StatTargetChars}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="/" Opacity="0.4" FontSize="18" />
                                        <TextBlock Text="{Binding StatSourceChars}" FontSize="18" Opacity="0.6" />
                                    </StackPanel>
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <!-- editing time + estimated time remaining -->
                        <Border Classes="card">
                            <UniformGrid Columns="2">
                                <StackPanel Spacing="2">
                                    <TextBlock Opacity="0.6" FontSize="12" Text="{loc:Localize Editor_Stats_Time}" />
                                    <TextBlock Text="{Binding EditingTimeText}" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Opacity="0.6" FontSize="12" Text="{loc:Localize Editor_Stats_Remaining}" />
                                    <TextBlock Text="{Binding EstimatedRemainingText}" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                            </UniformGrid>
                        </Border>

                        <!-- per-section progress -->
                        <TextBlock Text="{loc:Localize Editor_Stats_PerSection}" FontWeight="SemiBold" Margin="2,4,0,0" />
                        <ItemsControl ItemsSource="{Binding Sections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EditorSectionViewModel">
                                    <Grid ColumnDefinitions="180,*,Auto" Margin="0,0,0,7" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Fraction}"
                                                     Height="8" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding ProgressText}" Opacity="0.5" FontSize="11"
                                                   Margin="10,0,0,0" VerticalAlignment="Center" MinWidth="60" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Panel>
</UserControl>
